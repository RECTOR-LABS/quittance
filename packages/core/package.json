{
  "name": "@quittance/core",
  "version": "0.0.1",
  "private": true,
  "description": "Shared types, interfaces, signing primitive, and quorum logic for Quittance.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./test-utils": {
      "development": {
        "import": "./dist/test-utils.js",
        "types": "./dist/test-utils.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/ed25519": "^2.3.0",
    "@noble/hashes": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
