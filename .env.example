# --- Casper testnet (CSPR.cloud) ---
# Get an access token at https://console.cspr.build
CASPER_NODE_URL=https://node.testnet.cspr.cloud
CSPR_CLOUD_TOKEN=

# --- Funded testnet account ---
# Faucet: https://testnet.cspr.live/tools/faucet (once per account)
CASPER_SECRET_KEY_PATH=./secret_key.pem

# --- x402 facilitator (CSPR.cloud-hosted; serves mainnet + testnet) ---
# URL is a PUBLIC CONSTANT — no claim form. Endpoints: /supported /verify /settle.
# Auth: the facilitator requires a CSPR.cloud access token — the SAME value as
# CSPR_CLOUD_TOKEN above (one token unlocks the Node API AND the facilitator).
# Get it at https://console.cspr.build. The buildathon "sponsored" quota / $100k
# x402 credits layer ON TOP of this (announced via Casper Discord/Telegram) — a
# bonus, not required to start. Real x402 request header is PAYMENT-SIGNATURE.
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
# Leave blank to reuse CSPR_CLOUD_TOKEN (adapter falls back to it).
X402_FACILITATOR_API_KEY=

# --- Verifier service (x402-gated signed-verdict server) ---
# Shared across all verifier instances:
# Chain name only; the server prefixes CAIP-2 -> "casper:casper-test".
CASPER_NETWORK=casper-test
# WCSPR CEP-18 contract package hash (bare 64-hex, no 0x). Public testnet value:
WCSPR_PACKAGE_HASH=3d80df21ba4ee4d66a2a1f60c32570dd5685e4b279f6538162a5fd1314847c1e
# WCSPR EIP-712 domain — optional; defaults below match WCSPR. Changing these
# for WCSPR will break settlement (invalid_signature).
# WCSPR_TOKEN_NAME=Wrapped CSPR
# WCSPR_TOKEN_VERSION=1
#
# Per-instance (one set per verifier process):
VERIFIER_PORT=4101
VERIFIER_LABEL=verifier-node-1
# Ed25519 signing key, 32-byte lowercase hex. NEVER commit a real key —
# generate a throwaway for local/dev. Signs the verdict.
VERIFIER_SIGNING_KEY_HEX=
# Verifier's receiving account address: "00" + account-hash (66 hex).
VERIFIER_PAYTO=
# Price per verdict in motes (smallest unit), integer string.
VERIFIER_PRICE_MOTES=10000000000
# Path to the JSON cashflow-evidence fixture ("<assetId>:<cycleId>" -> evidence).
VERIFIER_EVIDENCE_PATH=./verifiers/evidence.example.json
# Reference the observed cashflow must carry to qualify.
VERIFIER_EXPECTED_REFERENCE=

# --- Deployed addresses (filled after Phase 1 deploy) ---
SERVICER_VAULT_HASH=
PAYOUT_TOKEN_HASH=

# --- LLM for agent narration (decisions stay deterministic) ---
# Use one: Claude API or Ollama Cloud
ANTHROPIC_API_KEY=
# OLLAMA_HOST=
